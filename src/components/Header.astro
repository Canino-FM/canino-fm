		mix-blend-mode: difference;
		color: #fff;
	}

	@media (min-width: 768px) {
		.header__container {
			display: flex;
			justify-content: space-between;
		}
	}

	.header .row {
		position: relative;
		z-index: 1;
		display: flex;
	}

	.header .symbol {
		height: 100vh;
		transition: height 1s ease;
		will-change: height;
	}

	.header .symbol svg {
		width: auto;
		height: 100%;
	}

	.header .symbol svg path {
		width: auto;
		height: 100%;
		fill: #fff;
	}

	body.loaded .header .symbol {
		height: calc(117 / 1920 * 100vw);
	}

	@media (max-width: 767px) {
		body.loaded .header .symbol {
			height: calc(59 / 375 * 100vw);
		}
	}

	body.no-transitions .header .symbol {
		transition: none;
	}

	.header .logo-wrapper {
		position: absolute;
		top: calc(12 / 1920 * 100vw);
		left: calc(103 / 1920 * 100vw);
		width: 0;
		height: calc(99 / 1920 * 100vw);
		overflow: hidden;
		transition: width 0.6s ease;
		will-change: width;
	}

	@media (max-width: 767px) {
		.header .logo-wrapper {
			left: calc(50 / 375 * 100vw);
			height: calc(40 / 375 * 100vw);
		}
	}

	.header .logo-wrapper .logo {
		position: absolute;
		top: 50%;
		left: 0;
		width: calc(855 / 1920 * 100vw);
		min-width: calc(855 / 1920 * 100vw);
		height: calc(99 / 1920 * 100vw);
		min-height: calc(99 / 1920 * 100vw);
		transform: translate3d(0, -50%, 0);
	}

	@media (max-width: 767px) {
		.header .logo-wrapper .logo {
			width: calc(317 / 375 * 100vw);
			min-width: calc(317 / 375 * 100vw);
			height: calc(40 / 375 * 100vw);
			min-height: calc(40 / 375 * 100vw);
		}
	}

	.header .logo-wrapper .logo svg {
		width: 100%;
		height: 100%;
	}

	.header .logo-wrapper .logo svg path {
		fill: #fff;
	}

	body.animated .header .logo-wrapper {
		width: calc(860 / 1920 * 100vw);
	}

	@media (max-width: 767px) {
		body.animated .header .logo-wrapper {
			width: calc(320 / 375 * 100vw);
		}
	}

	body.no-transitions .header .logo-wrapper {
		transition: none;
	}

	.header .nav {
		position: absolute;
		top: 0;
		right: 0;
		display: flex;
		justify-content: space-between;
		width: 100%;
		padding: calc(14 / 1920 * 100vw) calc(10 / 1920 * 100vw) calc(10 / 1920 * 100vw)
