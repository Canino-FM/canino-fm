		opacity: 0;
		pointer-events: none;
		transition: opacity 0.2s ease;
	}

	@media (max-width: 767px) {
		.header .nav {
			padding: calc(63 / 375 * 100vw) calc(5 / 375 * 100vw) 0;
		}
	}

	.header .nav .menu,
	.header .nav .list {
		display: flex;
	}

	.header .nav .item {
		margin-right: calc(20 / 1920 * 100vw);
		text-transform: uppercase;
		cursor: pointer;
	}

	@media (max-width: 767px) {
		.header .nav .item {
			margin-right: calc(10 / 375 * 100vw);
		}
	}

	.header .nav .item:last-child {
		margin: 0;
	}

	body.no-transitions .header .nav {
		opacity: 1;
		pointer-events: all;
	}

	.header .nav .desktop {
